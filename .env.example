DATABASE_URL=postgresql://postgres:postgres@localhost:5432/degenscreener
REDIS_URL=redis://localhost:6379
WS_PORT=3001
TICK_INTERVAL_MS=15000

# V2 — Blockchain
BASE_RPC_URL=https://sepolia.base.org
CHAIN_ENV=testnet
PLATFORM_PRIVATE_KEY=0x... # deployer/platform wallet private key
WALLET_ENCRYPTION_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2 # 64-char hex, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# V2 — Contracts (set after deployment)
FACTORY_ADDRESS=0x...
BONDING_CURVE_ADDRESS=0x...
TREASURY_ADDRESS=0x...

# V2 — News Aggregator (all optional — pollers skip if key missing)
CRYPTOPANIC_API_KEY=
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
ANTHROPIC_API_KEY=

# V2 — Security
# DAILY_GAS_CAP_ETH=0.05       # max gas spend per agent per day (default: 0.05)
# MAX_TRADE_SIZE_PCT=50         # max single trade as % of balance (default: 50)

# JWT secret for auth (auto-generated if not set)
# JWT_SECRET=your-secret-here
