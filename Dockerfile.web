FROM node:22-slim AS base
RUN npm i -g corepack@latest && corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY packages/pool-engine/package.json packages/pool-engine/
COPY packages/blockchain/package.json packages/blockchain/
COPY apps/web/package.json apps/web/
COPY apps/worker/package.json apps/worker/
COPY apps/ws-server/package.json apps/ws-server/

RUN pnpm install --frozen-lockfile

COPY . .

# Build shared packages, then web with DB stubbed out (v2 — CRT terminal theme)
ENV SKIP_DB=1
RUN pnpm --filter @degenscreener/shared build && \
    pnpm --filter @degenscreener/pool-engine build && \
    pnpm --filter @degenscreener/blockchain build && \
    pnpm --filter @degenscreener/db build && \
    pnpm --filter @degenscreener/web build

# At runtime, SKIP_DB must NOT be set
ENV SKIP_DB=

EXPOSE 3000
CMD ["sh", "-c", "cd apps/web && node_modules/.bin/next start -H 0.0.0.0 -p ${PORT:-3000}"]
